{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NicePod MCP Configuration Schema",
  "description": "Schema for validating Model Context Protocol server configurations.",
  "type": "object",
  "required": [
    "mcpServersCollection"
  ],
  "properties": {
    "mcpServersCollection": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "config"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "builtin",
              "external",
              "local"
            ]
          },
          "status": {
            "type": "string",
            "default": "active"
          },
          "config": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}