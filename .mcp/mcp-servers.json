{
  "$schema": "./config.schema.json",
  "mcpServersCollection": [
    {
      "name": "supabase-mcp-server",
      "type": "external",
      "config": {
        "supabaseUniformResourceLocator": "process.env.SUPABASE_URL",
        "supabaseServiceRoleKey": "process.env.SUPABASE_SERVICE_ROLE_KEY"
      }
    },
    {
      "name": "vercel-mcp-server",
      "type": "external",
      "config": {
        "vercelPersonalAccessToken": "process.env.VERCEL_API_TOKEN",
        "vercelProjectIdentification": "process.env.VERCEL_PROJECT_ID"
      }
    },
    {
      "name": "linear-mcp-server",
      "type": "external",
      "config": {
        "linearPersonalApiKey": "process.env.LINEAR_API_KEY"
      }
    },
    {
      "name": "playwright-mcp-server",
      "type": "local",
      "config": {
        "command": "npx",
        "args": [
          "playwright",
          "test"
        ]
      }
    }
  ]
}