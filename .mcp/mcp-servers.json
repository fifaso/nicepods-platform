{
  "$schema": "./config.schema.json",
  "mcpServersCollection": [
    {
      "name": "supabase-mcp-server",
      "type": "external",
      "config": {
        "supabaseUniformResourceLocator": "${SUPABASE_UNIFORM_RESOURCE_LOCATOR}",
        "supabaseServiceRoleKey": "${SUPABASE_SERVICE_ROLE_KEY}"
      }
    },
    {
      "name": "vercel-mcp-server",
      "type": "external",
      "config": {
        "vercelPersonalAccessToken": "${VERCEL_PERSONAL_ACCESS_TOKEN}",
        "vercelProjectIdentification": "${VERCEL_PROJECT_IDENTIFICATION}"
      }
    },
    {
      "name": "linear-mcp-server",
      "type": "external",
      "config": {
        "linearPersonalApiKey": "${LINEAR_API_KEY}"
      }
    },
    {
      "name": "playwright-mcp-server",
      "type": "local",
      "config": {
        "command": "npx",
        "args": [
          "-y",
          "@playwright/mcp@latest"
        ]
      }
    }
  ]
}